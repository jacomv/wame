API_KEY=cambia-esto-por-un-secret-seguro
PORT=3000
SESSION_DIR=/data/sessions

# Opcional: directorio de datos (sesiones, webhooks, base de datos SQLite)
DATA_DIR=/data

# Opcional: límites de rate limiting (peticiones por minuto)
RATE_LIMIT=100
SEND_RATE_LIMIT=30

# Opcional: CORS (default: * permite todo)
CORS_ORIGIN=*
